{
  "name": "cert-verify-platform",
  "version": "1.0.0",
  "private": true,
  "description": "电子证书跨机构可信验证平台",
  "scripts": {
    "install:all": "cd backend && npm install && cd ../frontend && npm install && cd ../contracts && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "compile:contracts": "cd contracts && npm run compile",
    "test:contracts": "cd contracts && npm test",
    "deploy:contracts": "cd contracts && npm run deploy:sepolia"
  }
}
