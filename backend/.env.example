# ============================================
# 后端环境变量配置模板
# 复制为 .env 并填入真实值后使用
# ============================================

# --- 服务 ---
PORT=3001
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- 数据库 (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=bishe

# --- JWT ---
JWT_SECRET=your_strong_random_secret_here
JWT_EXPIRES_IN=7d

# --- 密码加密 ---
BCRYPT_SALT_ROUNDS=10

# --- SMTP 邮件 ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
SMTP_FROM=your_email@example.com

# --- Pinata / IPFS ---
PINATA_JWT=your_pinata_jwt
# 或使用 API Key 方式:
# PINATA_API_KEY=your_pinata_api_key
# PINATA_SECRET_API_KEY=your_pinata_secret_api_key

# --- 区块链 ---
CERT_REGISTRY_ADDRESS=0x87d3D0CE658ec5E74f3f6da693dD85F26C033FdE
SEPOLIA_RPC_URL=https://sepolia.drpc.org

# --- 百度 OCR ---
BAIDU_OCR_API_KEY=your_baidu_ocr_api_key
BAIDU_OCR_SECRET_KEY=your_baidu_ocr_secret_key

# --- 跨机构验证加密 ---
VERIFY_AUTH_KEY=your_verify_auth_key
VERIFY_ENCRYPTION_SECRET=your_verify_encryption_secret
